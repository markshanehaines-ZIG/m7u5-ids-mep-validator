    <specifications>
<specification name="AHU nominal air flow rate" ifcVersion="IFC4" identifier="GEN-01" description="Every air-handling unit must declare its supply-air design flow rate via Pset_AirHandlingUnitTypeCommon.NominalAirFlowRate to enable verification against the room-by-room load schedule." instructions="Populate NominalAirFlowRate in Pset_AirHandlingUnitTypeCommon for every IFCAIRHANDLINGUNIT instance. Value must reflect the design supply-air flow rate used in the mechanical load calculations and be consistent with the commissioning schedule.">
    <applicability minOccurs="0" maxOccurs="unbounded">
        <entity><name><simpleValue>IFCAIRHANDLINGUNIT</simpleValue></name></entity>
    </applicability>
    <requirements>
        <property dataType="IFCVOLUMETRICFLOWRATEMEASURE" cardinality="required">
            <propertySet><simpleValue>Pset_AirHandlingUnitTypeCommon</simpleValue></propertySet>
            <baseName><simpleValue>NominalAirFlowRate</simpleValue></baseName>
        </property>
    </requirements>
</specification>
    </specifications>
</ids>
